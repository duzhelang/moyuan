# ==================== 编译产物 ====================
# Java编译文件
*.class
# Maven/Gradle构建目录
target/
build/
.gradle/
!gradle/wrapper/gradle-wrapper.jar
# 打包文件
*.jar
*.war
*.zip
*.tar.gz

# ==================== 环境与配置 ====================
# Spring Boot配置（排除通用配置，保留环境专属配置）
application-dev.yml
application-test.yml
application-prod.yml
*.env
.env
.env.local
# 敏感配置目录（API密钥、数据库密码等）
secrets/
# 数据库连接配置（敏感信息）
db-config.properties
# 会话/缓存文件
*.session
*.cache

# ==================== 日志与临时文件 ====================
# 日志目录/文件
logs/
*.log
temp/
tmp/
# JVM崩溃日志
hs_err_pid*
replay_pid*

# ==================== IDE/编辑器配置 ====================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
# VS Code
.vscode/
*.swp
*.swo
# Eclipse
.project
.classpath
.settings/
# 系统文件
.DS_Store
Thumbs.db

# ==================== 前端依赖 ====================
# Node.js依赖目录
node_modules/

# ==================== 归档目录 ====================
archive/
_archive/

# ==================== 本地目录（通过 .git/info/exclude 管理） ====================
# .trae/ 和 docs/ 已迁移至 .git/info/exclude 管理，不随仓库提交

# ==================== 项目专属过滤 ====================
# 订单统计临时生成的Excel/CSV文件
*.xlsx
*.csv
# 商家/用户会话临时数据
session-data/
# 第三方SDK临时文件（如百度AI/支付SDK）
sdk-tmp/